#!/usr/bin/env bash
# setup-codex — register this checkout as a Codex skill install, then run setup.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"
CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
SKILLS_DIR="$CODEX_HOME/skills"
GSTACK_DIR="$SKILLS_DIR/gstack"

mkdir -p "$SKILLS_DIR"

if [ -e "$GSTACK_DIR" ] && [ ! -L "$GSTACK_DIR" ]; then
  EXISTING="$(cd "$GSTACK_DIR" && pwd)"
  if [ "$EXISTING" != "$REPO_ROOT" ]; then
    echo "Refusing to overwrite existing Codex install at $GSTACK_DIR" >&2
    echo "Move it aside or set CODEX_HOME to a different location." >&2
    exit 1
  fi
fi

if [ -L "$GSTACK_DIR" ]; then
  EXISTING="$(cd "$GSTACK_DIR" && pwd)"
  if [ "$EXISTING" != "$REPO_ROOT" ]; then
    rm "$GSTACK_DIR"
    ln -s "$REPO_ROOT" "$GSTACK_DIR"
  fi
elif [ ! -e "$GSTACK_DIR" ]; then
  ln -s "$REPO_ROOT" "$GSTACK_DIR"
fi

"$GSTACK_DIR/setup"
