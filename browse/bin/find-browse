#!/bin/bash
# Shim: delegates to compiled find-browse binary, falls back to basic discovery.
# The compiled binary handles git root detection for workspace-local installs.
DIR="$(cd "$(dirname "$0")/.." && pwd)/dist"
if test -x "$DIR/find-browse"; then
  exec "$DIR/find-browse" "$@"
fi
# Fallback: basic discovery
if [ -n "${GSTACK_BROWSE_BIN:-}" ] && test -x "$GSTACK_BROWSE_BIN"; then
  echo "$GSTACK_BROWSE_BIN"
  exit 0
fi
ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
if [ -n "$ROOT" ] && test -x "$ROOT/.codex/skills/gstack/browse/dist/browse"; then
  echo "$ROOT/.codex/skills/gstack/browse/dist/browse"
elif test -x "$CODEX_HOME/skills/gstack/browse/dist/browse"; then
  echo "$CODEX_HOME/skills/gstack/browse/dist/browse"
elif [ -n "$ROOT" ] && test -x "$ROOT/.claude/skills/gstack/browse/dist/browse"; then
  echo "$ROOT/.claude/skills/gstack/browse/dist/browse"
elif test -x "$HOME/.claude/skills/gstack/browse/dist/browse"; then
  echo "$HOME/.claude/skills/gstack/browse/dist/browse"
else
  echo "ERROR: browse binary not found. Run ./setup-codex or set GSTACK_BROWSE_BIN." >&2
  exit 1
fi
